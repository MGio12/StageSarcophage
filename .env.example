# Configuration de l'application Modes Dégradés
# Copiez ce fichier vers .env et remplacez les valeurs

FLASK_ENV=development

# Clé secrète Flask (sessions, CSRF)
# Générer avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGEZ_MOI_64_CARACTERES_HEX

# Clé de chiffrement des identifiants (Fernet)
# Générer avec: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGEZ_MOI_CLE_FERNET_BASE64

# Répertoire de stockage local des PDF
STORAGE_DIR=/data/modes-degrades

# Fuseau horaire
TZ=Europe/Paris

# Déploiement production derrière reverse proxy HTTPS
# FORCE_HTTPS=true impose les redirections HTTPS côté Flask.
# Garder false si TLS est terminé par le proxy et que le conteneur reçoit du HTTP.
FORCE_HTTPS=false
TRUST_PROXY=false
SESSION_COOKIE_SECURE=false

# SMTP notifications et rapports
SMTP_HOST=smtp.example.local
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=modes-degrades@example.local
SMTP_USE_TLS=true

# LDAP / Active Directory
LDAP_ENABLED=false
LDAP_HOST=ad.example.local
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=DC=example,DC=local
LDAP_BIND_DN=CN=svc-modes-degrades,OU=Services,DC=example,DC=local
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(sAMAccountName={username})
LDAP_DEFAULT_ROLE=lecteur
LDAP_GROUP_MAPPING=
LDAP_SYNC_GROUPS=false

# Corbeille avant suppression définitive
CORBEILLE_RETENTION_JOURS=30

